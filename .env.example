# Harmonia – Environment Variables
# Copy to .env and fill in values before starting.
# Never commit .env to version control.
#
# Generate JWT_SECRET with: openssl rand -hex 32

# ---------------------------------------------------------------------------
# Navidrome (Backend)
# ---------------------------------------------------------------------------

# Internal Navidrome URL — used by the backend to trigger library rescans.
# In Docker Compose this is typically http://navidrome:4533
NAVIDROME_URL=http://navidrome:4533

# Admin Navidrome credentials — backend only, never exposed to the frontend.
# Used exclusively for POST /rest/startScan after a file is moved to the library.
NAVIDROME_ADMIN_USER=admin
NAVIDROME_ADMIN_PASS=changeme

# Non-admin Navidrome credentials — used by the frontend for all Subsonic API calls.
# Create this account manually in the Navidrome UI (Settings → Users).
# Must NOT be an admin account.
NAVIDROME_APP_USER=harmonia
NAVIDROME_APP_PASS=changeme

# ---------------------------------------------------------------------------
# JWT & Security (Backend)
# ---------------------------------------------------------------------------

# Random secret for signing JWTs and stream tokens (HMAC-SHA256).
# REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=

# JWT lifetime in days. Tokens auto-renew on activity. Default: 30.
JWT_EXPIRY_DAYS=30

# ---------------------------------------------------------------------------
# File Paths (Backend)
# ---------------------------------------------------------------------------

# Absolute path to the Navidrome music root (mounted as /music:ro in Navidrome).
MUSIC_LIBRARY_PATH=/data/library

# Absolute path to the in-progress download staging folder.
RAW_PATH=/data/raw

# Absolute path to the SQLite database file.
DB_PATH=/data/custom_metadata.db

# ---------------------------------------------------------------------------
# Workers (Backend)
# ---------------------------------------------------------------------------

# Age in hours before unconfirmed raw/ folders are deleted by the GC worker.
# Jobs actively open in the tagging panel are always skipped regardless of age.
# Default: 48
GC_RAW_MAX_AGE_HOURS=48

# ---------------------------------------------------------------------------
# Logging (Backend)
# ---------------------------------------------------------------------------

# Structlog level: DEBUG | INFO | WARNING | ERROR
# Use DEBUG in development to see all yt-dlp args and outbound proxy requests.
LOG_LEVEL=INFO

# Structlog renderer: json (production, use with Loki/Datadog) | pretty (dev terminal)
LOG_FORMAT=pretty

# ---------------------------------------------------------------------------
# Server (Backend)
# ---------------------------------------------------------------------------

HOST=0.0.0.0
PORT=8000

# ---------------------------------------------------------------------------
# MusicBrainz (Backend)
# ---------------------------------------------------------------------------

# App name component of the outbound User-Agent header sent to MusicBrainz.
# MusicBrainz API policy requires a descriptive User-Agent identifying the application.
MUSICBRAINZ_APP_NAME=Harmonia

# Contact URL included in the User-Agent per MusicBrainz API policy.
# Use your GitHub repo URL or a contact page.
# REQUIRED. Example: https://github.com/yourname/harmonia
MUSICBRAINZ_CONTACT_URL=

# ---------------------------------------------------------------------------
# Frontend (Next.js public env vars — injected at build time)
# ---------------------------------------------------------------------------

# Public-facing Navidrome URL for Subsonic API calls from the browser.
NEXT_PUBLIC_NAVIDROME_URL=http://localhost:4533

# Public-facing Acquisition Backend URL.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
